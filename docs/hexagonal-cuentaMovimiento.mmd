flowchart TD
    subgraph Dominio ["Dominio (Domain)"]
        CM[CuentaMovimiento<br/>Modelo de Dominio<br/>implements Jsonifyable]
        CR[CuentaMovimientoRepository<br/>Puerto de Salida]
        CU[Cuenta<br/>Modelo de Dominio]
        P[Proveedor<br/>Modelo de Dominio]
        CO[Comprobante<br/>Modelo de Dominio]
        PM[ProveedorMovimiento<br/>Modelo de Dominio]
        T[Track<br/>Modelo de Dominio]
    end

    subgraph Aplicacion ["Aplicación (Application)"]
        Svc[CuentaMovimientoService<br/>Servicio de Aplicación]
        UC1[CreateCuentaMovimientoUseCase]
        UC2[UpdateCuentaMovimientoUseCase]
        UC3[FindByCuentaMovimientoIdUseCase]
        UC4[FindAllByNumeroCuentaUseCase]
        UC5[FindAllByAsientoUseCase]
        UC6[FindAllByNumeroCuentaAndFechaContableBetweenAndAperturaUseCase]
        UC7[FindLastByFechaUseCase]
        UC8[DeleteByCuentaMovimientoIdUseCase]
        UC9[DeleteAllByCuentaMovimientoIdInUseCase]
        UC10[DeleteAsientoUseCase]
    end

    subgraph Infraestructura ["Infraestructura (Infrastructure)"]
        CC[CuentaMovimientoController<br/>Adaptador Web]
        JPA[JpaCuentaMovimientoRepositoryAdapter<br/>Adaptador JPA]
        CMM[CuentaMovimientoMapper<br/>Mapeador Dominio]
        DM[CuentaMovimientoDtoMapper<br/>Mapeador DTO]
        Req[CuentaMovimientoRequest<br/>DTO Entrada]
        Resp[CuentaMovimientoResponse<br/>DTO Salida]
        ENT[CuentaMovimientoEntity<br/>Entidad JPA]
    end

    subgraph Externo ["Externo (External)"]
        JPAR[JpaRepository<br/>Spring Data]
    end

