flowchart TD
    subgraph Dominio ["Dominio (Domain)"]
        C[Comprobante<br/>Modelo de Dominio]
        CR[ComprobanteRepository<br/>Puerto de Salida]
    end

    subgraph Aplicacion ["Aplicación (Application)"]
        Svc[ComprobanteService<br/>Servicio de Aplicación]
        UC1[GetAllComprobantesUseCase]
        UC2[GetAllComprobantesByOrdenPagoUseCase]
        UC3[GetAllComprobantesByTipoTransaccionIdUseCase]
        UC4[GetAllComprobantesByOrdenPagoAndTipoTransaccionIdUseCase]
        UC5[GetComprobanteByTipoTransaccionIdUseCase]
        UC6[GetComprobanteByIdUseCase]
    end

    subgraph Infraestructura ["Infraestructura (Infrastructure)"]
        CC[ComprobanteController<br/>Adaptador Web]
        JPA[JpaComprobanteRepositoryAdapter<br/>Adaptador JPA]
        CM[ComprobanteMapper<br/>Mapeador Dominio]
        DM[ComprobanteDtoMapper<br/>Mapeador DTO]
        Resp[ComprobanteResponse<br/>DTO Salida]
        ENT[ComprobanteEntity<br/>Entidad JPA]
    end

    subgraph Externo ["Externo (External)"]
        JPAR[JpaRepository<br/>Spring Data]
    end

